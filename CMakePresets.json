{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Host-native Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-arm64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    },
    {
      "name": "macos-x64",
      "displayName": "macOS x86_64 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_ARCHITECTURES": "x86_64"
      }
    },
    {
      "name": "macos-universal",
      "displayName": "macOS universal Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-universal",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64"
      }
    },
    {
      "name": "linux-native",
      "displayName": "Linux native Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-native",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ]
}
